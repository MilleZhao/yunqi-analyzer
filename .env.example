# ============================================================
# 云阙智能 — 大模型 API 配置文件
# 复制此文件为 .env 并填入你自己的 API Key
# ============================================================

# --- 文本分析 LLM（用于撰写爆款分析报告）---
# 提供商: deepseek / openai / custom
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-your-deepseek-key-here
LLM_MODEL=deepseek-chat
# 自定义 provider 时填写 base_url（OpenAI 兼容格式即可）
LLM_BASE_URL=https://api.deepseek.com/chat/completions

# --- 视觉分析 API（用于描述关键帧画面）---
# 提供商: ark(火山引擎) / openai / custom
VISION_PROVIDER=ark
VISION_API_KEY=ark-your-ark-key-here
VISION_MODEL=doubao-seed-1-8-251228
VISION_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# --- 飞书多维表格 + 文档导出（可选）---
# 需先安装 lark-cli 并认证: cli auth login --domain base
FEISHU_BASE_TOKEN=
FEISHU_TABLE_ID=
